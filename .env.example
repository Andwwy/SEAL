# Copy to .env and fill in. setup_runpod.sh and scripts/runpod_gsm.sh source this.
#   cp .env.example .env

# Hugging Face token (https://huggingface.co/settings/tokens).
# DeepSeek-R1-Distill-Qwen-1.5B is public/ungated, so a read token is optional
# for THIS run, but set it to avoid rate limits and to access gated models later.
HF_TOKEN=

# Where to cache downloaded models/datasets. On RunPod put this on the
# persistent network volume (/workspace) so re-runs don't re-download.
HF_HOME=/workspace/hf_cache

# GPU index to use (single A100 = 0).
GPU=0
